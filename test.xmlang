<xmlang version='1.0.0'>
<class to='c'>
<public>
<funct to='c' test='test'>
<string to='this.a'>{var: test}</string>
</funct>
<funct to='test'>
<builtins.current to='v' />
<print text='{v}'/>
<funct to='ret'>
<print text='hello world' />
</funct>
<return>{var: ret}</return>
</funct>
</public>
</class>
<c to='q' test='aaaaaaaaaaaaaAAa' />
<c to='w' test='z'/>
<q.test to='re'/>
<print text='{var: w.a}'/>
<re/>
</xmlang>